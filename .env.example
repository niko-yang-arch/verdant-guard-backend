# 数据库（Docker Compose 内部）
DATABASE_URL=postgresql://verdant:verdant_secret@postgres:5432/verdant_guard

# Redis
REDIS_URL=redis://redis:6379

# JWT（生产必须更换）
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=30d

# 跨域（前端地址，docker compose 环境填前端容器名）
CORS_ORIGIN=http://localhost:5173

# 微信登录（微信公众平台获取）
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_app_secret

# 阿里云 OSS
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=verdant-guard
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# MiniMax AI（https://platform.minimaxi.com/）
MINIMAX_API_KEY=your_minimax_api_key

# 服务端口
PORT=3000
NODE_ENV=production