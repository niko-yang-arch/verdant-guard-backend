// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(cuid())
  unionId       String?   @unique @map("union_id")  // 微信 UnionID
  openId        String?   @map("open_id")           // 微信 OpenID (同一主体下唯一)
  phone         String?   @unique
  nickname      String?
  avatar        String?   // OSS URL
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  plants        Plant[]
  images        Image[]
  feedbacks     Feedback[]

  @@map("users")
  @@index([unionId])
  @@index([openId])
  @@index([phone])
}

// 植物表
model Plant {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id")
  name          String                        // 植物称呼
  species       String                        // 种类
  frequency     Decimal                       // 浇水频率（整数）
  frequencyType FrequencyType                 // 频率类型：DAYS 或 TIMES_PER_DAY
  image         String?                       // OSS URL
  lastWatered   DateTime? @map("last_watered")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  waterLogs     WaterLog[]

  @@map("plants")
  @@index([userId])
  @@index([createdAt])
}

// 图片表
model Image {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  url         String
  type        ImageType // 图片类型
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("images")
  @@index([userId])
  @@index([createdAt])
}

// 浇水记录表
model WaterLog {
  id        String   @id @default(cuid())
  plantId   Int      @map("plant_id")
  userId    String   @map("user_id")         // 反范式：加速查询
  wateredAt DateTime @default(now()) @map("watered_at")

  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("water_logs")
  @@index([plantId])
  @@index([userId])
  @@index([wateredAt])
  @@index([plantId, wateredAt])
}

// 用户反馈表
model Feedback {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  type      FeedbackType
  content   String
  contact   String?
  userAgent String?      @map("user_agent")
  createdAt DateTime     @default(now()) @map("created_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

enum FrequencyType {
  DAYS           // 每 N 天浇水一次
  TIMES_PER_DAY  // 每天浇水 N 次
}

enum ImageType {
  PLANT  // 植物图片
  AVATAR // 用户头像
}

enum FeedbackType {
  bug
  suggestion
  other
}
